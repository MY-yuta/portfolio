<style is:global>
  /* Use Shippori Mincho for Latin characters only */
  @font-face {
    font-family: 'Shippori Mincho';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url(https://fonts.gstatic.com/s/shipporimincho/v17/VdGGAZweH5EbgHY6YExcZfDoj0Bw3PWD.woff2)
      format('woff2');
    unicode-range:
      U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC,
      U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193,
      U+2212, U+2215, U+FEFF, U+FFFD;
  }
  @font-face {
    font-family: 'Shippori Mincho';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url(https://fonts.gstatic.com/s/shipporimincho/v17/VdGDAZweH5EbgHY6YExcZfDoj0B4Z9CW45sP.woff2)
      format('woff2');
    unicode-range:
      U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC,
      U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193,
      U+2212, U+2215, U+FEFF, U+FFFD;
  }
  :root {
    --color-bg: #ffffff;
    --color-text-primary: #1a1a1a;
    --color-text-muted: #6b6b6b;
    --color-border: #e0e0e0;
    --color-accent: #cd853f;
    --border: 0.5px solid var(--color-border);
    --radius-card: 12px;
    --radius-tag: 8px;
    --font-family:
      'Shippori Mincho', -apple-system, BlinkMacSystemFont, 'Segoe UI',
      sans-serif;
    --font-size-h1: 24px;
    --font-size-h2: 20px;
    --font-size-entry-title: 15px;
    --font-size-body: 16px;
    --font-size-tag: 11px;
    --font-weight-heading: 600;
    --font-weight-body: 400;
    --line-height-body: 1.6;
    --spacing-section: 2.5rem;
    --spacing-entry: 1.5rem;
    --spacing-inner-section: 1rem;
  }
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
  }

  body {
    font-family: var(--font-family);
    font-size: var(--font-size-body);
    font-weight: var(--font-weight-body);
    line-height: var(--line-height-body);
    color: var(--color-text-primary);
    background: var(--color-bg);
    min-height: 100dvh;
    max-width: 680px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  h1 {
    font-size: var(--font-size-h1);
    font-weight: var(--font-weight-heading);
    color: var(--color-text-primary);
  }

  h2 {
    font-size: var(--font-size-h2);
    font-weight: var(--font-weight-heading);
    color: var(--color-text-muted);
    letter-spacing: 0.5px;
  }
</style>
