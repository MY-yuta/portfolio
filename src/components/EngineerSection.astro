---
// Engineer.astro — Engineer content section
import TimelineEntry from './TimelineEntry.astro';
import CertCard from './CertCard.astro';
import tuxivSNS from '../assets/TuxivSNS.png';
import tuxivSchedule from '../assets/TuxivSchedule.png';
import combustion from '../assets/Combustion.png';
---

<section class="engineer" data-section="engineer">
  <h2>Work experience</h2>
  <div class="timeline">
    <TimelineEntry
      date="2024年8月 - 2026年4月"
      title="株式会社FreeWeb｜エンジニア（業務委託）"
      description="SaaS(magic-lpo)の開発に従事。エンジニア3名体制の中で週30~40時間コミットし、AI分析パイプラインの設計・実装、GoogleCloudのインフラ、フロントエンド改修など幅広く担当。"
      tags={['TypeScript', 'Next.js', 'Google Cloud', 'Terraform', 'Supabase']}
    />
    <TimelineEntry
      date="2025年"
      title="コーポレートサイト採用ページ制作｜FreeWeb"
      description="Astroを用いたコーポレートサイトの採用ページ制作を担当。"
      tags={['Astro']}
    />
  </div>

  <h2>Personal projects</h2>
  <div class="timeline">
    <TimelineEntry
      date="2025年7月 - 現在"
      title="Tuxiv｜サークル向け画像共有SNS・日程調整アプリ"
      description="所属しているサークル（50人強）のために個人開発。ファンアート共有SNSとして開始し、役職別の日程調整機能を追加。メンバーの改善要望をもとに継続的に開発、運営。"
      tags={['TypeScript', 'Next.js', 'Google Cloud', 'MongoDB Atlas']}
      images={[tuxivSNS, tuxivSchedule]}
    />
    <TimelineEntry
      date="2024年5月 - 2024年12月"
      title="燃焼シミュレーションの実装"
      description="大学の授業の一環で、燃焼シミュレーションを実装。"
      tags={['C++', 'OpenGL']}
      images={[combustion]}
    />
    <TimelineEntry
      date="2024年1月 - 現在"
      title="サークルWebページ保守・運営"
      description="演劇サークル公式Webページの保守・更新。大学サーバ上のPHP環境で運用。"
      url="https://www.stb.tsukuba.ac.jp/~tsukusho/"
      tags={['PHP', 'MySQL']}
    />
  </div>

  <h2>Certifications</h2>
  <div class="certs">
    <CertCard
      name="GCP Associate Cloud Engineer"
      date="2025年5月"
      badgeId="c36a7f64-0bbd-48ba-9a65-ed37856ee72f"
    />
    <CertCard
      name="GCP Professional Cloud Architect"
      date="2025年7月"
      badgeId="fce49679-847b-479c-95ed-6b2e0afcd328"
    />
  </div>
</section>

<style>
  .engineer {
    padding: var(--spacing-section) 0;
  }

  h2 {
    margin-bottom: 12px;
  }

  .timeline {
    border-left: 2px solid var(--color-border);
    padding-left: var(--spacing-entry);
    margin-bottom: var(--spacing-section);
    border-radius: 0;
  }

  .certs {
    margin-bottom: var(--spacing-section);
  }
  @media (max-width: 768px) {
    .certs {
      flex-direction: column;
    }
  }
</style>
